                      className={`w-9 h-9 rounded-xl transition-all duration-150 ${grpColor === c ? 'ring-2 ring-white/50 scale-110' : 'hover:scale-105'}`}
                      style={{ backgroundColor: c }} />
                  ))}
                </div>
              </div>
              <p className={`text-xs font-bold ${txM} uppercase tracking-wider mb-2`}>Участники ({grpMembers.length} выбрано)</p>
            </div>
            <div className="flex-1 overflow-y-auto px-6 pb-4 space-y-2">
              {D.others.map(u => {
                const sel = grpMembers.includes(u.id);
                return (
                  <button key={u.id} onClick={() => setGrpMembers(p => sel ? p.filter(x => x !== u.id) : [...p, u.id])}
                    className={`w-full flex items-center gap-3 p-3 rounded-xl border transition-all duration-150 ${sel ? (dark ? 'bg-violet-600/15 border-violet-500/30' : 'bg-violet-50 border-violet-300') : (dark ? 'bg-white/[0.02] border-white/[0.04]' : 'bg-gray-50 border-gray-200')}`}>
                    {avatar(u.displayName, u.avatar, 34)}
                    <span className={`font-medium ${txP}`}>{u.displayName}</span>
                    {sel && <Check size={16} className="text-violet-400 ml-auto" />}
                  </button>
                );
              })}
              {D.others.length === 0 && <p className={`text-center py-8 ${txM}`}>Пользователей не найдено</p>}
            </div>
            <div className={`p-6 pt-4 border-t ${bdr}`}>
              <div className="flex gap-3">
                <button onClick={() => setGrpOpen(false)} className={`flex-1 py-3 rounded-xl font-medium ${dark ? 'bg-white/[0.04] text-white/50' : 'bg-gray-100 text-gray-500'}`}>Отмена</button>
                <button onClick={createGrp} disabled={!grpName.trim() || !grpMembers.length}
                  className="flex-1 py-3 rounded-xl bg-gradient-to-r from-violet-600 to-cyan-500 text-white font-semibold disabled:opacity-30 transition-opacity">Создать</button>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
});
